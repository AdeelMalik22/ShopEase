					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract CSRF token from cookies",
									"var csrfToken = pm.cookies.get('csrftoken');",
									"if (csrfToken) {",
									"    pm.collectionVariables.set('csrf_token', csrfToken);",
									"    console.log('CSRF Token saved:', csrfToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/accounts/login/",
							"host": ["{{base_url}}"],
							"path": ["accounts", "login", ""]
						},
						"description": "Get CSRF token by visiting login page. Run this first before other requests."
					}
